{
  "name": "git-pull-dir",
  "version": "0.3.0",
  "description": "A CLI tool to clone a specific directory from a remote git repository to local, designed for syncing skills managed by internal GitLab into projects.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "git-pull-dir": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tangjiahui-cn/git-pull-dir.git"
  },
  "homepage": "https://github.com/tangjiahui-cn/git-pull-dir#readme",
  "bugs": {
    "url": "https://github.com/tangjiahui-cn/git-pull-dir/issues"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --outDir dist",
    "lint": "eslint src/ test/ --ext .ts",
    "test": "vitest run",
    "test:unit": "vitest run test/cli.test.ts test/clone.test.ts",
    "test:integration": "vitest run test/clone.integration.test.ts",
    "prepublishOnly": "pnpm run build && pnpm test",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "version": "pnpm changelog && git add CHANGELOG.md",
    "postversion": "git push --follow-tags"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "keywords": [
    "git",
    "sparse-checkout",
    "partial-clone",
    "sparse-clone",
    "gitlab",
    "skills",
    "subdirectory",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "conventional-changelog-cli": "^5.0.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.7.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "execa": "^9.6.1"
  }
}
