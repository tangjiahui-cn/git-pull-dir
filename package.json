{
  "name": "git-pull-dir",
  "version": "0.1.0",
  "description": "Clone only a specific directory from a git repository using sparse-checkout",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "git-pull-dir": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --outDir dist",
    "lint": "eslint src/ test/ --ext .ts",
    "test": "vitest run",
    "test:unit": "vitest run test/cli.test.ts test/clone.test.ts",
    "test:integration": "vitest run test/clone.integration.test.ts",
    "prepublishOnly": "pnpm run build && pnpm test"
  },
  "keywords": [
    "git",
    "sparse-checkout",
    "partial-clone",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "execa": "^10.0.0"
  }
}
